{
  "name": "grepline",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "if [ -d .git ]; then husky; fi && bunx effect-language-service patch",
    "check": "bun --filter './apps/*' check",
    "build": "bun --filter './apps/*' build",
    "dev": "bun --filter '@grepline/cli' dev"
  },
  "packageManager": "bun@1.3.7",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@effect/language-service": "^0.75.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.49.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
